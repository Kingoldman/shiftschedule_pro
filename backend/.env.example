# 生产环境配置示例
# 复制为 .env 后修改

# 关闭调试模式（禁用 /docs 文档、收紧安全策略）
DEBUG=False

# 数据库（生产可用 PostgreSQL 等）
# DATABASE_URL=postgresql://user:pass@localhost:5432/shiftschedule

# JWT 密钥（必须更换为随机长字符串！）
# 可用: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-random-secret-key-here

# CORS 允许的前端域名（生产环境改为实际域名）
# CORS_ORIGINS=["https://your-domain.com"]
